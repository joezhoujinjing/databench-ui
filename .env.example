# API base used by the frontend fetch client.
# Default is '/api', which the Vite dev server proxies to the FastAPI backend.
# Set to an absolute URL (e.g. http://127.0.0.1:8000) to talk to a backend directly.
VITE_API_BASE=/api

# Optional: override the dev proxy target (defaults to http://127.0.0.1:8000).
# Only used by vite.config.ts during `npm run dev`.
VITE_PROXY_TARGET=http://127.0.0.1:8000
