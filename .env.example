# The API base is configured at RUNTIME from the UI (top-right connection panel)
# and persisted in localStorage under 'databench.api_base'. It is an ORIGIN ONLY
# (e.g. http://127.0.0.1:8000) — the client appends /v1 itself. There is no
# build-time VITE_API_BASE.

# Optional: override the dev proxy target (defaults to http://127.0.0.1:8000).
# Only used by vite.config.ts during `npm run dev`, which proxies /v1 and the
# meta routes (/health, /version, /capabilities) to this backend.
VITE_PROXY_TARGET=http://127.0.0.1:8000
