{
  "name": "databench-ui",
  "private": true,
  "version": "0.2.2",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "tsc --noEmit",
    "typecheck": "tsc -b",
    "gen:client": "openapi-typescript schema/openapi.json -o src/api/generated/schema.ts",
    "gen:client:check": "openapi-typescript schema/openapi.json -o src/api/generated/schema.ts && git diff --exit-code -- src/api/generated/schema.ts"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.59.0",
    "@tanstack/react-virtual": "^3.14.3",
    "i18next": "^23.16.8",
    "i18next-browser-languagedetector": "^8.2.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^14.1.3",
    "react-router-dom": "^6.26.2"
  },
  "devDependencies": {
    "@types/node": "^20.19.43",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.2",
    "openapi-typescript": "^7.13.0",
    "typescript": "^5.6.2",
    "vite": "^5.4.8"
  }
}
